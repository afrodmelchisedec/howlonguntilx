// FILE: prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  paypalId      String?   @unique
  plan          Plan      @default(FREE)
  eventCount    Int       @default(0)
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  lastSeen      DateTime?

  accounts  Account[]
  sessions  Session[]
  timers    Timer[]
  likes     Like[]
  follows   Follow[]
}

enum Plan {
  FREE
  PRO
}

enum Role {
  USER
  ADMIN
}

model Category {
  id          String     @id @default(cuid())
  slug        String     @unique
  name        String
  emoji       String
  description String
  parentId    String?
  parent      Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children    Category[] @relation("SubCategories")
  events      Event[]
  createdAt   DateTime   @default(now())
}

model Timer {
  id         String   @id @default(cuid())
  userId     String
  name       String
  targetDate DateTime
  category   String   @default("personal")
  isPublic   Boolean  @default(false)
  slug       String?  @unique
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Event {
  id           String    @id @default(cuid())
  slug         String    @unique
  name         String
  description  String?
  targetDate   DateTime
  type         EventType @default(COUNTDOWN)
  categoryId   String?
  category     Category? @relation(fields: [categoryId], references: [id])
  categorySlug String    @default("leisure")
  published    Boolean   @default(true)
  archived     Boolean   @default(false)
  userId       String?
  locale       String    @default("en")
  views        Int       @default(0)
  likeCount    Int       @default(0)
  followCount  Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  content      Json?

  likes   Like[]
  follows Follow[]
}

enum EventType {
  COUNTDOWN
  ELAPSED
  RELATIVE
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model Follow {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

