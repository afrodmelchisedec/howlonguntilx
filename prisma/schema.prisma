// Also add inside `model User { ... }`:  articles Article[]  (only if you want an authorId relation — optional, see authorName fallback below)

model Article {
  id           String    @id @default(cuid())
  toolSlug     String // e.g. "tech-events" — links article to its parent tool/category
  slug         String
  title        String
  dek          String // one-line SEO/social summary
  heroImageUrl String // must be >=1200px wide
  heroImageAlt String
  authorName   String    @default("Editorial Team")
  blocks       Json // typed block array, see ArticleBlocks.tsx
  status       String    @default("draft") // draft | published | archived
  contentType  String    @default("evergreen") // evergreen | breaking
  publishedAt  DateTime?
  updatedAt    DateTime  @updatedAt
  createdAt    DateTime  @default(now())

  @@unique([toolSlug, slug])
  @@index([toolSlug, status, publishedAt])
}

model FeaturedPiece {
  id          String    @id @default(cuid())
  kind        String    // "history" | "fact" | "quote" | "meme"
  title       String
  body        String    @db.Text   // 300-500 words, plain paragraphs joined by \n\n
  sourceLabel String?              // e.g. "NIST" or "Guinness World Records" — omit if none
  sourceUrl   String?
  imageUrl    String?
  weekOf      DateTime?            // set ONLY to pin this piece to a specific ISO week (override); null = part of the auto-rotating pool
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@index([active, weekOf])
}
